# Copia este archivo a .env.local y rellena los valores reales.
# En Vercel / GitHub Actions, agrega estas mismas variables como env vars / secrets.

# ── Supabase (Settings → API del proyecto) ───────────────────────────────
SUPABASE_URL=https://tu-proyecto.supabase.co
# Llave anon (pública). Respaldo si no hay service role.
SUPABASE_KEY=eyJ...
# Llave service_role (secreta). La usa el scraper para leer/escribir la tabla.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Groq (https://console.groq.com) ──────────────────────────────────────
GROQ_API_KEY=gsk_...
# Opcional: modelo a usar (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Email diario (SendGrid) ──────────────────────────────────────────────
# El envío real está desactivado (stub en src/mailer.js). La llave se usará
# cuando se active; el destinatario recibe el resumen diario de ofertas.
SENDGRID_API_KEY=SG.xxxxx
RECIPIENT_EMAIL=alvarosalinass@hotmail.com
# Base del webhook de aceptación de perfiles (cuando se despliegue en Vercel)
# WEBHOOK_BASE_URL=https://tu-proyecto.vercel.app
# WEBHOOK_SECRET=un-secreto-largo

# ── Login en portales de empleo (para completar postulaciones) ───────────
# Credenciales de TUS PROPIAS cuentas. En GitHub van como Secrets, nunca en
# el código ni en logs. Déjalas vacías para no intentar login (las
# postulaciones quedarán como "login_failed").
COMPUTRABAJO_EMAIL=
COMPUTRABAJO_PASSWORD=
TRABAJANDO_EMAIL=
TRABAJANDO_PASSWORD=
LABORUM_EMAIL=
LABORUM_PASSWORD=

# ── Perfiles públicos propios (para src/scrapers/profile-scraper.js) ──────
# URLs de tus perfiles públicos; se leen solo para consolidar tu experiencia.
PROFILE_URL_COMPUTRABAJO=
PROFILE_URL_TRABAJANDO=
PROFILE_URL_LABORUM=

# ── Búsqueda ─────────────────────────────────────────────────────────────
# Términos separados por coma (incluye aerolíneas y bienestar)
SEARCH_TERMS=coordinador operaciones,supervisor logistica,mejora procesos,aerolíneas,bienestar
# Perfil del candidato: Groq lo usa para puntuar la afinidad de cada oferta
CANDIDATE_PROFILE=Profesional 13+ años en operaciones, supervisión de equipos, logística y coordinación.
# Rango salarial objetivo en CLP
MIN_SALARY=840000
MAX_SALARY=1200000
LOCATION=Santiago
# Antigüedad máxima de las ofertas (días)
DAYS_BACK=14

# ── Anti-bot ─────────────────────────────────────────────────────────────
# Probabilidad (0 a 1) de que un ciclo sea "de reposo": scrapea y evalúa
# pero no postula. Default: 0.3 (30% de los ciclos).
REST_CYCLE_PROB=0.3
# Con SETUP_MODE=1, npm start solo valida la configuración sin buscar nada.
# SETUP_MODE=1

# ── Cron (solo referencia) ───────────────────────────────────────────────
# El schedule real vive en .github/workflows/job-search.yml (en UTC).
CRON_SCHEDULE=0 9,13,16,20,23 * * 1-5
